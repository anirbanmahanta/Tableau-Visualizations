      </column>
      <column caption='Profit Category' datatype='string' name='[Calculation_0997870433050625]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Profit] &lt;0 THEN &quot;Loss&quot;&#13;&#10;ELSEIF [Profit]/[Sales] &lt;0.5 THEN &quot;Low Profit&quot;&#13;&#10;ELSE &quot;High Profit&quot;&#13;&#10;END' />
      </column>
      <column caption='Priority Category' datatype='string' name='[Calculation_0997870440214533]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Profit]) &lt; 0 THEN &quot;Loss Product&quot;&#13;&#10;ELSEIF SUM([Profit]) / SUM([Sales]) &lt; 0.05 THEN &quot;Low Profit Product&quot;&#13;&#10;ELSEIF SUM([Sales]) &gt; 1000 AND SUM([Quantity]) &gt; 5 THEN &quot;High Priority&quot;&#13;&#10;ELSE &quot;Medium Priority&quot;&#13;&#10;END' />
      </column>
